<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Account Panel</title>
    <link rel="stylesheet" href="/css/cashier.css">
</head>
<body>
    {{> navbar}}

    <div class="main">
        {{#if messages.success}}
            <div class="form-message success">{{messages.success}}</div>
        {{/if}}

        {{#if messages.error}}
            <div class="form-message error">{{messages.error}}</div>
        {{/if}}

        {{#if Users}}
        <div id="productlist-base">

            <!-- This Part searches the user accounts  -->
            <div id="productlist-options">
                <div id="search-container">
                    <div id="search-icon">
                        <button id="search-button"><i class="fa fa-search"></i></button>
                    </div>
                    <form id="search-form" method="get" action="/expense">
                        <input id="search-bar" type="search" name="q" placeholder="Search accounts...">
                    </form>
                </div>

                <!-- This Part adds account by the admin -->
                <div id="add-product-container">
                    <a href="/addexpense">
                        <button id="add-product-button">Add Account</button>
                    </a>
                </div>
            </div>

            <!-- This Part is the table where the admin can see all the accounts given  -->
            <div class="product-table-container">
                <table class="product-table">
                    <thead>
                        <tr>
                            <th>Username</th>
                            <th>Password</th>
                            <th>Role</th>
                            <th>Last Updated</th>
                            <th>Edit</th>
                        </tr>
                    </thead>

                    <tbody>
                    {{#each Users}}
                    <tr id="row-{{this._id}}">
                        <td>{{this.username}}</td>

                        <!-- This Part does not show the password -->
                        <td>********</td>

                        <td>{{this.role}}</td>

                        <td>{{formatDate this.passwordChangedAt}}</td>

                        <td>
                            <a href="/edit-user/{{this._id}}">
                            <button class="edit-button">Edit</button>
                            </a>
                            <button type="button" class="delete-button" onclick="deleteUser('{{this._id}}')">❌</button>
                        </td>
                    </tr>
                    {{/each}}
                    </tbody>
                </table>
            </div>
        </div>

        {{else}}

        <!-- This Part displays if there are no users available in the db  -->
        <div id="productlist-options">
            <div id="search-container">
                <form id="search-form" method="get" action="/expense">
                    <input id="search-bar" type="search" name="q" placeholder="Search accounts...">
                </form>
            </div>

            <div id="add-product-container">
                <a href="/addexpense">
                    <button id="add-product-button">Add Account</button>
                </a>
            </div>
        </div>

        <div id="notfound-base">
            <div id="notfound-container">
                <h1>No Accounts Found</h1>
                <p>No account records available.</p>
                <a href="/expense"><button>Refresh</button></a>
            </div>
        </div>

        {{/if}}
    </div>

    <!-- This Part is the javascript  -->
<script>
function deleteUser(id) {
    if (!confirm("Are you sure you want to delete this account?")) return;

    fetch(`/delete-user/${id}`, {
        method: "DELETE",
    })
    .then(res => {
        if (res.ok) {
            location.reload();
        } else {
            alert("Failed to delete user");
        }
    })
    .catch(err => {
        console.error(err);
        alert("Error deleting user");
    });
}
</script>

    {{> footer}}
</body>
</html>