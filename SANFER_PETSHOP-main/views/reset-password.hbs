<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password</title>
    <link rel="stylesheet" href="/css/login.css">
</head>

    <style>
        .password-requirements {
            display: none;
            position: absolute;
            background-color: #f9f9f9;
            border: 1px solid #ddd;
            padding: 10px;
            border-radius: 5px;
            z-index: 1;
            width: 250px;
            text-align: left;
            font-size: 0.9em;
            margin-top: 5px;
        }

        #password:hover + .password-requirements,
        #password:focus + .password-requirements {
            display: block;
        }
    </style>

<body>
    {{> navbar}}

    <main>
        <div class="container">
            <h2>Reset Password</h2>

            {{#if messages.error}}
                <div class="alert alert-danger">{{messages.error}}</div>
            {{/if}}
            {{#if messages.success}}
                <div class="alert alert-success">{{messages.success}}</div>
            {{/if}}

            {{#if securityQuestion}}
                <div class="security-question">
                    <h4>Security Question</h4>
                    <p>{{securityQuestion}}</p>
                    <form action="/auth/verify-security" method="POST">
                        <input type="hidden" name="userId" value="{{userId}}">
                        <div class="form-group">
                            <label for="securityAnswer">Your Answer:</label>
                            <input type="password" class="form-control" id="securityAnswer" name="securityAnswer" required>
                        </div>
                        <button type="submit" class="btn btn-primary">Verify Answer</button>
                    </form>    
                </div>
            {{/if}}

            {{#if securityVerified}}
                <form action="/auth/reset-password" method="POST">
                    <input type="hidden" name="userId" value="{{userId}}">
                <div class="form-group">
                    <label for="password">Password:</label>
                    <input type="password" id="password" name="password" required>
                    <div class="password-requirements">
                        <p>At least one lowercase letter</p>
                        <p>At least one uppercase letter</p>
                        <p>At least one digit</p>
                        <p>At least one special character (@$!%*?&)</p>
                        <p>Minimum length 12 characters</p>
                    </div>
                </div>
                    <div class="form-group">
                        <label for="confirmPassword">Confirm Password:</label>
                        <input type="password" id="confirmPassword" name="confirmPassword" required minlength="8">
                    </div>
                    <button type="submit" class="btn btn-primary">Reset Password</button>
                </form>
            {{/if}}
        </div>
    </main>
</body>
</html>